# ============================================================
# Discord (Gateway bot)
# ============================================================
DISCORD_BOT_TOKEN=
# Comma-separated guild text channel IDs the bot will listen to. Leave empty to ignore all Discord messages.
DISCORD_ALLOWED_CHANNEL_IDS=
# Comma-separated user IDs whose messages will be treated as callouts.
DISCORD_ALLOWED_AUTHOR_IDS=
# Optional destination channel where allowed source messages are mirrored before parsing/trading.
DISCORD_FORWARD_CHANNEL_ID=
# Set true while debugging Discord ingestion. Logs why messages are ignored.
DISCORD_LOG_IGNORED_MESSAGES=false

# ============================================================
# LLM (callout parser)
# ============================================================
# Provider for structured callout extraction. One of: ollama | openai | anthropic
# Startup fails if unset or set to any other value.
LLM_PROVIDER=ollama
# Model name for the selected provider
# (e.g. qwen3:8b for ollama, gpt-4o for openai, claude-sonnet-4-5 for anthropic).
# Temperature 0 is applied for deterministic parsing, except on OpenAI
# reasoning models (o*/gpt-5*), which don't accept a temperature param.
LLM_MODEL=qwen3:8b
# Used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
# API keys: required only when the matching cloud provider is selected.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ============================================================
# Trader HTTP server
# ============================================================
TRADER_PORT=3000
# Interface the trader binds to. WARNING: 0.0.0.0 exposes the unauthenticated
# settings API to your network — keep 127.0.0.1 outside Docker.
TRADER_HOST=127.0.0.1
# All channels forward to this single endpoint.
TRADER_WEBHOOK_URL=http://localhost:3000/webhook/discord
# Shared secret used to HMAC-sign bot -> trader webhook requests.
# Generate with: openssl rand -hex 32
BOT_TRADER_SECRET=

# Optional: URL of the client dashboard's in-memory session-settings endpoint.
# When set, the trader pulls it per message (500ms timeout) and merges the
# values like a payload override. Resolution chain: webhook payload override
# -> this pull -> state/settings.json -> env defaults; any pull failure
# silently falls through to the next layer. Unset = pull skipped entirely.
# CLIENT_SETTINGS_URL=http://localhost:3001/api/settings-state

# Trade execution behavior: immediate | approval
# immediate submits orders as soon as a callout passes risk checks.
# approval parses/risk-checks/logs callouts and posts an approval-required receipt without submitting.
TRADE_EXECUTION_MODE=immediate

# ============================================================
# Robinhood Trading MCP
# ============================================================
ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
ROBINHOOD_OAUTH_CALLBACK_PORT=8788
# Bind listener host. 0.0.0.0 is friendlier for WSL/Windows browser redirects.
ROBINHOOD_OAUTH_CALLBACK_HOST=0.0.0.0
# Host the browser is redirected to. The redirect URI defaults to
# http://<REDIRECT_HOST>:<CALLBACK_PORT>/oauth/callback, so you usually only
# need to change this (e.g. to your WSL IP from `hostname -I`).
ROBINHOOD_OAUTH_REDIRECT_HOST=127.0.0.1
# Optional full override of the derived redirect URI above.
# ROBINHOOD_OAUTH_REDIRECT_URI=http://127.0.0.1:8788/oauth/callback

# ============================================================
# Risk controls — all sizing is expressed as % of buying power
# These are the env-fallback DEFAULTS of the settings resolution chain:
# webhook payload override -> client pull (CLIENT_SETTINGS_URL)
# -> state/settings.json (PUT /api/settings) -> env.
# ============================================================

# Max equity notional per trade as % of buying power.
# e.g. 5 = "at most 5% of available capital on any single equity order"
MAX_NOTIONAL_PCT_PER_TRADE=5

# Max options premium spend per trade as % of buying power.
# Premium cost = contracts × mark_price × 100.
MAX_OPTIONS_NOTIONAL_PCT=2

# Hard floor: skip any options trade where even 1 contract would cost more
# than this % of buying power. Prevents entering over-sized positions when
# the account is small or the premium is unusually high.
# e.g. 5 = skip if 1 contract > 5% of buying power
MAX_SINGLE_CONTRACT_PCT=5

# How much of the per-trade cap to use for each size keyword (% of cap).
# "full" is always 100% of the cap.
POSITION_SMALL_PCT=25
POSITION_MEDIUM_PCT=50

# Example at $10,000 buying power with defaults above:
#   equity  full   → 5%   = $500
#   equity  medium → 2.5% = $250
#   equity  small  → 1.25%= $125
#   options full   → 2%   = $200  (~2 contracts at $1 premium)
#   options small  → 0.5% = $50   (1 contract at $0.50 premium)

MAX_TRADES_PER_DAY=10
COOLDOWN_SECONDS_PER_TICKER=300
# "*" allows any ticker. Otherwise comma-separated: AAPL,MSFT,NVDA
ALLOWED_TICKERS=*
BLOCKED_TICKERS=
REGULAR_HOURS_ONLY=true
MIN_CONFIDENCE=0.7

# ============================================================
# Paths
# ============================================================
# Relative paths resolve from the process cwd (server/), i.e. server/state/.
DECISION_LOG_PATH=state/decisions.jsonl
RISK_STATE_PATH=state/risk.json
RH_TOKENS_PATH=state/rh-tokens.json
SETTINGS_PATH=state/settings.json
